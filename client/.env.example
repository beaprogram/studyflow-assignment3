# Base URL the client prepends to API paths.
#
# Leave this EMPTY for normal use. An empty value means the app calls the
# relative path "/api/...", which Vite (dev) and Netlify (prod) proxy to the
# live Render backend. This is the CORS-free path and the recommended setup.
#
# Only set this to the full Render URL if you specifically want the browser to
# call the backend directly. If you do, you must add this front-end's origin
# to the API's CORS allow-list, or the browser will block the requests.
#
# VITE_API_BASE=https://studyflow-api-yzno.onrender.com

VITE_API_BASE=
