# ---------------------------------------------------------------------------
# StudyFlow API - environment variables
# Copy this file to ".env" and fill in real values. NEVER commit the real .env.
# ---------------------------------------------------------------------------

# Server
PORT=5000
NODE_ENV=development

# MongoDB connection string.
# Local:  mongodb://127.0.0.1:27017/studyflow
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/studyflow?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/studyflow

# JSON Web Token settings
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=2h

# CORS - comma separated list of allowed origins (front-end URLs)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
