{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "title": "StudyFlow API \u2014 Performance & Health",
  "tags": [
    "studyflow",
    "csci5709"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU usage (% of one core)",
      "description": "Rate of CPU seconds consumed by the API process, user + system.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(process_cpu_user_seconds_total{app=\"studyflow-api\"}[1m]) * 100",
          "legendFormat": "user",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        },
        {
          "refId": "B",
          "expr": "rate(process_cpu_system_seconds_total{app=\"studyflow-api\"}[1m]) * 100",
          "legendFormat": "system",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Memory usage",
      "description": "Resident set size of the process, and heap actually used by V8.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "process_resident_memory_bytes{app=\"studyflow-api\"}",
          "legendFormat": "resident (RSS)",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        },
        {
          "refId": "B",
          "expr": "nodejs_heap_size_used_bytes{app=\"studyflow-api\"}",
          "legendFormat": "heap used",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Request latency (p50 / p95 / p99)",
      "description": "Percentiles computed from the request-duration histogram.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{app=\"studyflow-api\"}[1m])) by (le))",
          "legendFormat": "p50",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{app=\"studyflow-api\"}[1m])) by (le))",
          "legendFormat": "p95",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{app=\"studyflow-api\"}[1m])) by (le))",
          "legendFormat": "p99",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Error rate (% of requests 4xx/5xx)",
      "description": "Share of requests returning a client or server error. Sits at 0 when healthy.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(http_requests_total{app=\"studyflow-api\",status_code=~\"4..|5..\"}[1m])) or vector(0)) / clamp_min(sum(rate(http_requests_total{app=\"studyflow-api\"}[1m])), 0.001) * 100",
          "legendFormat": "error %",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Throughput (requests/sec by route)",
      "description": "Request rate per matched route pattern.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{app=\"studyflow-api\"}[1m])) by (route)",
          "legendFormat": "{{route}}",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Requests in flight",
      "description": "Concurrent requests being processed. Rises under load, returns to 0 when idle.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "http_requests_in_flight{app=\"studyflow-api\"}",
          "legendFormat": "in flight",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      }
    }
  ],
  "uid": "studyflow-a3"
}