# Dependencies
node_modules/
**/node_modules/

# Build output
dist/
**/dist/

# Environment files (never commit real secrets)
.env
.env.local
**/.env
!**/.env.example

# JMeter run artifacts (keep exported CSVs, ignore raw logs)
*.jtl
jmeter.log
**/*.jtl

# Generated JMeter HTML dashboards are reproducible from the submitted CSVs.
# Keeping them out of Git avoids committing hundreds of vendored report assets.
jmeter/report-*/

# OS / editor
.DS_Store
*.log
